<Window x:Class="MetaQuestFileManager.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Meta Quest File Manager"
        Width="1180"
        Height="820"
        MinWidth="880"
        MinHeight="620"
        Loaded="OnLoaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="76" />
            <RowDefinition Height="*" />
            <RowDefinition Height="48" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid Margin="24,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock FontFamily="Bahnschrift SemiBold"
                               FontSize="22"
                               Text="Meta Quest File Manager" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="{StaticResource MutedTextBrush}"
                               Text="Browse accessible storage and move APKs through authorized ADB." />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel Margin="0,0,10,0">
                        <TextBlock Margin="0,0,0,4"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   Text="Selected headset" />
                        <ComboBox x:Name="DeviceBox"
                                  Width="330"
                                  DisplayMemberPath="DisplayName"
                                  SelectionChanged="OnDeviceSelectionChanged" />
                    </StackPanel>
                    <Button x:Name="RefreshDevicesButton"
                            Style="{StaticResource SecondaryButton}"
                            VerticalAlignment="Bottom"
                            Click="OnRefreshDevices"
                            Content="Refresh" />
                </StackPanel>
            </Grid>
        </Border>

        <TabControl x:Name="MainTabs" Grid.Row="1" Margin="20,18,20,14">
            <TabItem Header="Files">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Margin="0,0,10,0"
                                   VerticalAlignment="Center"
                                   Text="Device path" />
                        <TextBox x:Name="RemotePathBox" Grid.Column="1" Text="/sdcard" />
                        <Button Grid.Column="2"
                                Margin="10,0,0,0"
                                Style="{StaticResource SecondaryButton}"
                                Click="OnGoToRemotePath"
                                Content="Open" />
                        <Button Grid.Column="3"
                                Margin="8,0,0,0"
                                Style="{StaticResource SecondaryButton}"
                                Click="OnGoUp"
                                Content="Up" />
                    </Grid>

                    <DataGrid x:Name="RemoteEntriesGrid"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              BorderBrush="{StaticResource BorderBrush}"
                              BorderThickness="1"
                              MouseDoubleClick="OnRemoteEntryDoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                            <DataGridTextColumn Header="Type" Binding="{Binding TypeLabel}" Width="120" />
                            <DataGridTextColumn Header="Remote path" Binding="{Binding FullPath}" Width="2*" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <Grid Grid.Row="2" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Click="OnPullSelected" Content="Pull selected file" />
                        <Button Grid.Column="1"
                                Margin="8,0,0,0"
                                Style="{StaticResource SecondaryButton}"
                                Click="OnPushFile"
                                Content="Push file here" />
                        <TextBlock Grid.Column="2"
                                   Margin="16,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   TextAlignment="Right"
                                   Text="Delete and recursive folder mutation are intentionally unavailable." />
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Wi-Fi ADB">
                <Grid Margin="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="18" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Padding="22"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                        <StackPanel>
                            <TextBlock FontFamily="Bahnschrift SemiBold"
                                       FontSize="18"
                                       Text="Enable Wi-Fi ADB" />
                            <TextBlock Margin="0,8,0,18"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       TextWrapping="Wrap"
                                       Text="First connect and authorize a headset by USB, select that USB headset above, and keep the PC and headset on the same Wi-Fi network. The app reads the headset address, enables TCP/IP debugging, and connects to it." />

                            <TextBlock Margin="0,0,0,5" Text="TCP port" />
                            <TextBox x:Name="WifiEnablePortBox"
                                     Width="120"
                                     HorizontalAlignment="Left"
                                     Text="5555" />
                            <Button Margin="0,16,0,0"
                                    HorizontalAlignment="Left"
                                    Click="OnEnableWifiAdb"
                                    Content="Enable and connect" />

                            <Border Margin="0,22,0,0"
                                    Padding="14"
                                    Background="#FFF7E8"
                                    BorderBrush="#E8C981"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                <TextBlock TextWrapping="Wrap"
                                           Text="This changes the headset's debugging transport and always asks for confirmation. It does not reset the ADB server. Wi-Fi ADB can stop after a reboot, network change, or authorization change." />
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Padding="22"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                        <StackPanel>
                            <TextBlock FontFamily="Bahnschrift SemiBold"
                                       FontSize="18"
                                       Text="Connect an enabled headset" />
                            <TextBlock Margin="0,8,0,18"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       TextWrapping="Wrap"
                                       Text="Use this when Wi-Fi ADB is already enabled and you know the headset's local IPv4 address." />

                            <TextBlock Margin="0,0,0,5" Text="Headset IPv4 address or hostname" />
                            <TextBox x:Name="WifiHostBox" />

                            <TextBlock Margin="0,14,0,5" Text="TCP port" />
                            <TextBox x:Name="WifiConnectPortBox"
                                     Width="120"
                                     HorizontalAlignment="Left"
                                     Text="5555" />

                            <StackPanel Margin="0,16,0,0" Orientation="Horizontal">
                                <Button Click="OnConnectWifiAdb" Content="Connect" />
                                <Button Margin="8,0,0,0"
                                        Style="{StaticResource SecondaryButton}"
                                        Click="OnDisconnectWifiAdb"
                                        Content="Disconnect selected Wi-Fi headset" />
                            </StackPanel>

                            <TextBlock Margin="0,22,0,0"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       TextWrapping="Wrap"
                                       Text="After connecting, refresh the device list. Wi-Fi headsets appear with a [Wi-Fi] label and can be checked together in the APKs tab." />
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem x:Name="ApksTab" Header="APKs (ADB default)">
                <Grid Margin="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="18" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Padding="20"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock FontFamily="Bahnschrift SemiBold"
                                           FontSize="18"
                                           Text="Install APKs" />
                                <TextBlock Margin="0,6,0,18"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           TextWrapping="Wrap"
                                           Text="Install one APK or one complete base-and-split package set. Android reports signing, version, ABI, and package conflicts." />

                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               VerticalAlignment="Center"
                                               Text="Wi-Fi headsets for parallel install" />
                                    <Button Grid.Column="1"
                                            Padding="9,4"
                                            Style="{StaticResource SecondaryButton}"
                                            Click="OnSelectAllWifiTargets"
                                            Content="Select all" />
                                    <Button Grid.Column="2"
                                            Margin="6,0,0,0"
                                            Padding="9,4"
                                            Style="{StaticResource SecondaryButton}"
                                            Click="OnClearWifiTargets"
                                            Content="Clear" />
                                </Grid>
                                <Border Height="112"
                                        Padding="8"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsControl x:Name="WifiInstallTargetsList">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <CheckBox Margin="2,3"
                                                              IsChecked="{Binding IsSelected}"
                                                              Content="{Binding DisplayName}" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Border>
                                <Grid Margin="0,8,0,18">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               Text="Check at least two connected Wi-Fi headsets." />
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <TextBlock Margin="0,0,7,0"
                                                   VerticalAlignment="Center"
                                                   Text="Parallel limit" />
                                        <TextBox x:Name="ParallelismBox" Width="50" Text="4" />
                                    </StackPanel>
                                </Grid>

                                <TextBlock Margin="0,0,0,5" Text="Single APK file" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="InstallApkPathBox" Grid.Column="0" />
                                    <Button Grid.Column="1"
                                            Margin="8,0,0,0"
                                            Style="{StaticResource SecondaryButton}"
                                            Click="OnBrowseInstallApk"
                                            Content="Browse…" />
                                </Grid>
                                <StackPanel Margin="0,12,0,0" Orientation="Horizontal">
                                    <Button Click="OnInstallApk" Content="Install on selected headset" />
                                    <Button Margin="8,0,0,0"
                                            Style="{StaticResource SecondaryButton}"
                                            Click="OnInstallApkMany"
                                            Content="Install on checked Wi-Fi headsets" />
                                </StackPanel>

                                <Separator Margin="0,20,0,18" />

                                <TextBlock Margin="0,0,0,5" Text="APK bundle folder" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="InstallApkBundlePathBox" Grid.Column="0" />
                                    <Button Grid.Column="1"
                                            Margin="8,0,0,0"
                                            Style="{StaticResource SecondaryButton}"
                                            Click="OnBrowseInstallApkBundle"
                                            Content="Browse…" />
                                </Grid>
                                <TextBlock Margin="0,6,0,0"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           TextWrapping="Wrap"
                                           Text="Every top-level .apk file is installed together as one package set. Subfolders are ignored." />
                                <StackPanel Margin="0,12,0,0" Orientation="Horizontal">
                                    <Button Click="OnInstallApkBundle" Content="Install bundle on selected headset" />
                                    <Button Margin="8,0,0,0"
                                            Style="{StaticResource SecondaryButton}"
                                            Click="OnInstallApkBundleMany"
                                            Content="Install bundle on checked Wi-Fi headsets" />
                                </StackPanel>

                                <TextBlock Margin="0,20,0,5" Text="Install options" />
                                <CheckBox x:Name="ReplaceExistingBox" IsChecked="True" Content="Reinstall over an existing package" />
                                <CheckBox x:Name="AllowDowngradeBox" Content="Allow version downgrade" />
                                <CheckBox x:Name="GrantPermissionsBox" Content="Grant eligible runtime permissions" />
                                <CheckBox x:Name="AllowTestPackageBox" Content="Allow APKs marked test-only" />
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <Border Grid.Column="2"
                            Padding="20"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0"
                                       FontFamily="Bahnschrift SemiBold"
                                       FontSize="18"
                                       Text="Export an installed APK" />
                            <Grid Grid.Row="1" Margin="0,6,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           TextWrapping="Wrap"
                                           Text="Third-party packages only. Split packages cannot be exported yet." />
                                <Button Grid.Column="1"
                                        Margin="10,0,0,0"
                                        Style="{StaticResource SecondaryButton}"
                                        Click="OnRefreshPackages"
                                        Content="Refresh packages" />
                            </Grid>
                            <ListBox x:Name="PackagesList"
                                     Grid.Row="2"
                                     BorderBrush="{StaticResource BorderBrush}"
                                     BorderThickness="1" />
                            <Button Grid.Row="3"
                                    Margin="0,12,0,0"
                                    HorizontalAlignment="Left"
                                    Click="OnExportPackage"
                                    Content="Export selected package…" />
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Rusty Kiosk">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="18" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="18" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="18" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Padding="20"
                                Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.2*" />
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock FontFamily="Bahnschrift SemiBold"
                                               FontSize="18"
                                               Text="Install and connect Rusty Kiosk" />
                                    <TextBlock Margin="0,6,0,14"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               TextWrapping="Wrap"
                                               Text="Optional integration. Files, Wi-Fi ADB, and APK tools remain available when Rusty Kiosk is absent. The default Windows release includes both same-signer Kiosk APKs; a source build can select a staged bundle folder." />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="KioskBundlePathBox" IsReadOnly="True" />
                                        <Button Grid.Column="1"
                                                Margin="8,0,0,0"
                                                Style="{StaticResource SecondaryButton}"
                                                Click="OnBrowseKioskBundle"
                                                Content="Choose bundle…" />
                                    </Grid>
                                    <TextBlock x:Name="KioskBundleStatusText"
                                               Margin="0,6,0,0"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               Text="Kiosk bundle not located." />
                                    <StackPanel Margin="0,14,0,0" Orientation="Horizontal">
                                        <Button Click="OnInstallKiosk" Content="Install and provision (USB)" />
                                        <Button Margin="8,0,0,0"
                                                Style="{StaticResource SecondaryButton}"
                                                Click="OnProvisionKiosk"
                                                Content="Provision installed helper" />
                                        <Button Margin="8,0,0,0"
                                                Style="{StaticResource SecondaryButton}"
                                                Click="OnRefreshKiosk"
                                                Content="Refresh status" />
                                    </StackPanel>
                                    <TextBlock Margin="0,18,0,6"
                                               FontFamily="Bahnschrift SemiBold"
                                               FontSize="16"
                                               Text="Direct link after setup" />
                                    <TextBlock Foreground="{StaticResource MutedTextBrush}"
                                               TextWrapping="Wrap"
                                               Text="Enable the direct link in the headset panel, then enter its address and pairing code. This path needs Wi-Fi, but not ADB." />
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.2*" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="KioskDirectEndpointBox" ToolTip="For example http://192.168.137.42:39873" />
                                        <TextBox x:Name="KioskDirectPairingCodeBox" Grid.Column="2" ToolTip="Pairing code shown in Rusty Kiosk" />
                                    </Grid>
                                    <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                                        <Button Click="OnConnectKioskDirect" Content="Connect without ADB" />
                                        <Button Margin="8,0,0,0"
                                                Style="{StaticResource SecondaryButton}"
                                                Click="OnDisconnectKioskDirect"
                                                Content="Disconnect direct link" />
                                    </StackPanel>
                                    <TextBlock x:Name="KioskDirectStatusText"
                                               Margin="0,6,0,0"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               Text="Direct link: not connected" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock FontFamily="Bahnschrift SemiBold"
                                               FontSize="18"
                                               Text="Transparent status" />
                                    <TextBlock x:Name="KioskInstallStatusText" Margin="0,10,0,0" Text="Rusty Kiosk: not checked" />
                                    <TextBlock x:Name="KioskSetupStatusText" Margin="0,5,0,0" Text="USB setup: not checked" />
                                    <TextBlock x:Name="KioskWifiStatusText" Margin="0,5,0,0" Text="Wireless debugging: not checked" />
                                    <TextBlock x:Name="KioskAutoWifiStatusText" Margin="0,5,0,0" Text="Request after restart: not checked" />
                                    <TextBlock x:Name="KioskAccessibilityStatusText" Margin="0,5,0,0" Text="Accessibility guard: not checked" />
                                    <TextBlock x:Name="KioskSyncStatusText"
                                               Margin="0,12,0,0"
                                               FontWeight="SemiBold"
                                               Text="PC/headset sync: no state-changing command sent" />
                                    <TextBlock Margin="0,12,0,0"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               TextWrapping="Wrap"
                                               Text="The first install/provision needs authorized USB-C ADB. Meta's wireless-debugging approval remains a visible wearer decision." />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.35*" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Padding="20"
                                    Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="280" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock FontFamily="Bahnschrift SemiBold"
                                               FontSize="18"
                                               Text="Apps, search, tags, and launch" />
                                    <Grid Grid.Row="1" Margin="0,12,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="220" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="KioskSearchBox"
                                                 TextChanged="OnKioskFilterChanged"
                                                 ToolTip="Search app name, package, or tag" />
                                        <ComboBox x:Name="KioskTagFilterBox"
                                                  Grid.Column="2"
                                                  SelectionChanged="OnKioskFilterChanged" />
                                    </Grid>
                                    <ListBox x:Name="KioskAppsList"
                                             Grid.Row="2"
                                             SelectionChanged="OnKioskAppSelectionChanged"
                                             BorderBrush="{StaticResource BorderBrush}"
                                             BorderThickness="1">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="4,5">
                                                    <TextBlock FontWeight="SemiBold" Text="{Binding DisplayLabel}" />
                                                    <TextBlock Margin="0,2,0,0"
                                                               Foreground="{StaticResource MutedTextBrush}"
                                                               Text="{Binding PackageName}" />
                                                    <TextBlock Margin="0,2,0,0"
                                                               Foreground="{StaticResource MutedTextBrush}"
                                                               Text="{Binding TagLabel}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                    <StackPanel Grid.Row="3" Margin="0,12,0,0">
                                        <StackPanel Orientation="Horizontal">
                                            <Button Click="OnKioskLaunchNormal" Content="Normal launch" />
                                            <Button Margin="8,0,0,0" Click="OnKioskLaunchGuarded" Content="Kiosk launch" />
                                        </StackPanel>
                                        <Grid Margin="0,10,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="12" />
                                                <ColumnDefinition Width="180" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="KioskTagEditorBox" ToolTip="New tag" />
                                            <Button Grid.Column="1" Margin="8,0,0,0" Click="OnAddKioskTag" Content="Add tag" />
                                            <ComboBox x:Name="KioskSelectedTagsBox" Grid.Column="3" />
                                            <Button Grid.Column="4"
                                                    Margin="8,0,0,0"
                                                    Style="{StaticResource SecondaryButton}"
                                                    Click="OnRemoveKioskTag"
                                                    Content="Remove" />
                                        </Grid>
                                        <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                                            <Button Style="{StaticResource SecondaryButton}"
                                                    Click="OnExportKioskTags"
                                                    Content="Export tag file…" />
                                            <Button Margin="8,0,0,0"
                                                    Style="{StaticResource SecondaryButton}"
                                                    Click="OnImportKioskTags"
                                                    Content="Import and hotload…" />
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Grid.Column="2"
                                    Padding="20"
                                    Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                <StackPanel>
                                    <TextBlock FontFamily="Bahnschrift SemiBold"
                                               FontSize="18"
                                               Text="Kiosk user controls" />
                                    <TextBlock Margin="0,6,0,14"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               TextWrapping="Wrap"
                                               Text="These are the same fixed operations as the headset panel. Each change asks for confirmation and refreshes effective state." />
                                    <WrapPanel>
                                        <Button Margin="0,0,8,8" Click="OnKioskRequestWifiAdb" Content="Request Wi-Fi ADB" />
                                        <Button Margin="0,0,8,8" Style="{StaticResource SecondaryButton}" Click="OnKioskDisableWifiAdb" Content="Disable Wi-Fi ADB" />
                                        <Button Margin="0,0,8,8" Click="OnKioskEnableAutoWifi" Content="Ask after restart" />
                                        <Button Margin="0,0,8,8" Style="{StaticResource SecondaryButton}" Click="OnKioskDisableAutoWifi" Content="Stop asking" />
                                        <Button Margin="0,0,8,8" Click="OnKioskEnableAccessibility" Content="Enable Accessibility" />
                                        <Button Margin="0,0,8,8" Style="{StaticResource SecondaryButton}" Click="OnKioskDisableAccessibility" Content="Disable Accessibility" />
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Grid.Row="4"
                                Padding="20"
                                Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.15*" />
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock FontFamily="Bahnschrift SemiBold"
                                               FontSize="18"
                                               Text="Direct file staging (no ADB)" />
                                    <TextBlock Margin="0,6,0,10"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               TextWrapping="Wrap"
                                               Text="A bounded app-owned area for transferring files. It does not expose protected app data or arbitrary headset paths." />
                                    <ListBox x:Name="KioskDirectStagingList"
                                             Height="150"
                                             DisplayMemberPath="DisplayLabel"
                                             BorderBrush="{StaticResource BorderBrush}"
                                             BorderThickness="1" />
                                    <WrapPanel Margin="0,10,0,0">
                                        <Button Margin="0,0,8,8" Click="OnUploadKioskDirectFile" Content="Upload file…" />
                                        <Button Margin="0,0,8,8" Style="{StaticResource SecondaryButton}" Click="OnDownloadKioskDirectFile" Content="Download selected…" />
                                        <Button Margin="0,0,8,8" Style="{StaticResource SecondaryButton}" Click="OnRefreshKioskDirectStaging" Content="Refresh" />
                                        <Button Margin="0,0,8,8" Style="{StaticResource SecondaryButton}" Click="OnDeleteKioskDirectFile" Content="Delete selected" />
                                    </WrapPanel>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock FontFamily="Bahnschrift SemiBold"
                                               FontSize="18"
                                               Text="APK installation" />
                                    <TextBlock Margin="0,6,0,10"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               TextWrapping="Wrap"
                                               Text="Recommended: install from the PC over authorized ADB. This avoids an in-headset confirmation and supports unattended single or batch installs." />
                                    <Button HorizontalAlignment="Left"
                                            Click="OnOpenAdbApkInstaller"
                                            Content="Use ADB installer (default)" />
                                    <Separator Margin="0,16,0,14" />
                                    <TextBlock FontFamily="Bahnschrift SemiBold"
                                               Text="Optional local install" />
                                    <TextBlock Margin="0,6,0,10"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               TextWrapping="Wrap"
                                               Text="Use this only when ADB is unavailable. Choose one base APK or one complete base-and-split set. Android asks the wearer to confirm each app installation session." />
                                    <TextBox x:Name="KioskDirectApkPathsBox"
                                             IsReadOnly="True"
                                             TextWrapping="Wrap"
                                             ToolTip="Selected APK parts" />
                                    <WrapPanel Margin="0,8,0,0">
                                        <Button Margin="0,0,8,8" Style="{StaticResource SecondaryButton}" Click="OnChooseKioskDirectApks" Content="Choose local-install APK(s)…" />
                                        <Button Margin="0,0,8,8" Style="{StaticResource SecondaryButton}" Click="OnInstallKioskDirectApks" Content="Stage for headset confirmation" />
                                        <Button Margin="0,0,8,8" Style="{StaticResource SecondaryButton}" Click="OnRefreshKioskDirectInstall" Content="Refresh receipt" />
                                    </WrapPanel>
                                    <TextBlock x:Name="KioskDirectInstallStatusText"
                                               Margin="0,6,0,0"
                                               TextWrapping="Wrap"
                                               Text="Local install: no request sent" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Row="6"
                                Padding="20"
                                Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.1*" />
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock FontFamily="Bahnschrift SemiBold"
                                               FontSize="18"
                                               Text="Power and batteries" />
                                    <TextBlock x:Name="HeadsetBatteryText" Margin="0,10,0,0" Text="Headset battery: not checked" />
                                    <TextBlock x:Name="ControllerBatteryText" Margin="0,5,0,0" Text="Controllers: not checked" TextWrapping="Wrap" />
                                    <TextBlock x:Name="KeepAwakeStatusText" Margin="0,5,0,0" Text="Keep awake: not checked" />
                                    <Grid Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock VerticalAlignment="Center" Text="Duration (ms)" />
                                        <TextBox x:Name="KeepAwakeDurationBox" Grid.Column="1" Margin="8,0,0,0" Text="28800000" />
                                        <Button Grid.Column="2" Margin="10,0,0,0" Click="OnEnableKeepAwake" Content="Keep awake" />
                                        <Button Grid.Column="3" Margin="8,0,0,0" Style="{StaticResource SecondaryButton}" Click="OnDisableKeepAwake" Content="Restore normal" />
                                    </Grid>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock FontFamily="Bahnschrift SemiBold"
                                               FontSize="18"
                                               Text="Fixed CPU and GPU levels" />
                                    <TextBlock x:Name="PerformanceStatusText" Margin="0,10,0,0" Text="CPU/GPU: not checked" />
                                    <StackPanel Margin="0,12,0,0" Orientation="Horizontal">
                                        <TextBlock VerticalAlignment="Center" Text="CPU" />
                                        <ComboBox x:Name="CpuLevelBox" Width="70" Margin="8,0,14,0" />
                                        <TextBlock VerticalAlignment="Center" Text="GPU" />
                                        <ComboBox x:Name="GpuLevelBox" Width="70" Margin="8,0,14,0" />
                                        <Button Click="OnApplyPerformance" Content="Apply fixed levels" />
                                        <Button Margin="8,0,0,0" Style="{StaticResource SecondaryButton}" Click="OnClearPerformance" Content="App controlled" />
                                    </StackPanel>
                                    <Button Margin="0,12,0,0"
                                            HorizontalAlignment="Left"
                                            Style="{StaticResource SecondaryButton}"
                                            Click="OnRefreshQuestControls"
                                            Content="Refresh power and performance" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText"
                           Grid.Column="0"
                           VerticalAlignment="Center"
                           Text="Ready." />
                <ProgressBar x:Name="OperationProgressBar"
                             Grid.Column="1"
                             Width="180"
                             Height="7"
                             Margin="18,0"
                             VerticalAlignment="Center"
                             Background="#E5E1D8"
                             BorderThickness="0"
                             Foreground="{StaticResource AccentBrush}"
                             Focusable="False"
                             IsHitTestVisible="False"
                             Maximum="100"
                             Minimum="0"
                             Visibility="Collapsed" />
                <TextBlock x:Name="AdbPathText"
                           Grid.Column="2"
                           MaxWidth="360"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource MutedTextBrush}"
                           TextTrimming="CharacterEllipsis" />
            </Grid>
        </Border>
    </Grid>
</Window>
