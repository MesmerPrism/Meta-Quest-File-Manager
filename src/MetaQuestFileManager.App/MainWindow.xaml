<Window x:Class="MetaQuestFileManager.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Meta Quest File Manager"
        Width="1120"
        Height="760"
        MinWidth="880"
        MinHeight="620"
        Loaded="OnLoaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="76" />
            <RowDefinition Height="*" />
            <RowDefinition Height="38" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid Margin="24,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock FontFamily="Bahnschrift SemiBold"
                               FontSize="22"
                               Text="Meta Quest File Manager" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="{StaticResource MutedTextBrush}"
                               Text="Browse accessible storage and move APKs through authorized ADB." />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel Margin="0,0,10,0">
                        <TextBlock Margin="0,0,0,4"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   Text="Selected headset" />
                        <ComboBox x:Name="DeviceBox"
                                  Width="330"
                                  DisplayMemberPath="DisplayName"
                                  SelectionChanged="OnDeviceSelectionChanged" />
                    </StackPanel>
                    <Button x:Name="RefreshDevicesButton"
                            Style="{StaticResource SecondaryButton}"
                            VerticalAlignment="Bottom"
                            Click="OnRefreshDevices"
                            Content="Refresh" />
                </StackPanel>
            </Grid>
        </Border>

        <TabControl x:Name="MainTabs" Grid.Row="1" Margin="20,18,20,14">
            <TabItem Header="Files">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Margin="0,0,10,0"
                                   VerticalAlignment="Center"
                                   Text="Device path" />
                        <TextBox x:Name="RemotePathBox" Grid.Column="1" Text="/sdcard" />
                        <Button Grid.Column="2"
                                Margin="10,0,0,0"
                                Style="{StaticResource SecondaryButton}"
                                Click="OnGoToRemotePath"
                                Content="Open" />
                        <Button Grid.Column="3"
                                Margin="8,0,0,0"
                                Style="{StaticResource SecondaryButton}"
                                Click="OnGoUp"
                                Content="Up" />
                    </Grid>

                    <DataGrid x:Name="RemoteEntriesGrid"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              BorderBrush="{StaticResource BorderBrush}"
                              BorderThickness="1"
                              MouseDoubleClick="OnRemoteEntryDoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                            <DataGridTextColumn Header="Type" Binding="{Binding TypeLabel}" Width="120" />
                            <DataGridTextColumn Header="Remote path" Binding="{Binding FullPath}" Width="2*" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <Grid Grid.Row="2" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Click="OnPullSelected" Content="Pull selected file" />
                        <Button Grid.Column="1"
                                Margin="8,0,0,0"
                                Style="{StaticResource SecondaryButton}"
                                Click="OnPushFile"
                                Content="Push file here" />
                        <TextBlock Grid.Column="2"
                                   Margin="16,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   TextAlignment="Right"
                                   Text="Delete and recursive folder mutation are intentionally unavailable." />
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="APKs">
                <Grid Margin="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="18" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Padding="20"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                        <StackPanel>
                            <TextBlock FontFamily="Bahnschrift SemiBold"
                                       FontSize="18"
                                       Text="Install an APK" />
                            <TextBlock Margin="0,6,0,18"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       TextWrapping="Wrap"
                                       Text="Choose an APK you are allowed to install. Android reports signing, version, ABI, and package conflicts." />

                            <TextBlock Margin="0,0,0,5" Text="APK file" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="InstallApkPathBox" Grid.Column="0" />
                                <Button Grid.Column="1"
                                        Margin="8,0,0,0"
                                        Style="{StaticResource SecondaryButton}"
                                        Click="OnBrowseInstallApk"
                                        Content="Browse…" />
                            </Grid>

                            <TextBlock Margin="0,18,0,5" Text="Install options" />
                            <CheckBox x:Name="ReplaceExistingBox" IsChecked="True" Content="Reinstall over an existing package" />
                            <CheckBox x:Name="AllowDowngradeBox" Content="Allow version downgrade" />
                            <CheckBox x:Name="GrantPermissionsBox" Content="Grant eligible runtime permissions" />
                            <CheckBox x:Name="AllowTestPackageBox" Content="Allow APKs marked test-only" />

                            <Button Margin="0,18,0,0"
                                    HorizontalAlignment="Left"
                                    Click="OnInstallApk"
                                    Content="Install on selected headset" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Padding="20"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0"
                                       FontFamily="Bahnschrift SemiBold"
                                       FontSize="18"
                                       Text="Export an installed APK" />
                            <Grid Grid.Row="1" Margin="0,6,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           TextWrapping="Wrap"
                                           Text="Third-party packages only. Split installs are refused in this release." />
                                <Button Grid.Column="1"
                                        Margin="10,0,0,0"
                                        Style="{StaticResource SecondaryButton}"
                                        Click="OnRefreshPackages"
                                        Content="Refresh packages" />
                            </Grid>
                            <ListBox x:Name="PackagesList"
                                     Grid.Row="2"
                                     BorderBrush="{StaticResource BorderBrush}"
                                     BorderThickness="1" />
                            <Button Grid.Row="3"
                                    Margin="0,12,0,0"
                                    HorizontalAlignment="Left"
                                    Click="OnExportPackage"
                                    Content="Export selected package…" />
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText"
                           Grid.Column="0"
                           VerticalAlignment="Center"
                           Text="Ready." />
                <TextBlock x:Name="AdbPathText"
                           Grid.Column="1"
                           MaxWidth="520"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource MutedTextBrush}"
                           TextTrimming="CharacterEllipsis" />
            </Grid>
        </Border>
    </Grid>
</Window>
